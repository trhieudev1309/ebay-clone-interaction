@model IEnumerable<EbayChat.Entities.Dispute>
@{
    ViewData["Title"] = "Dispute Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-shield-exclamation text-danger"></i> Resolution Center</h2>
        <div>
            @if (Context.Session.GetString("role") == "Seller") {
                <span class="badge bg-info text-dark">Seller Dashboard</span>
            } else {
                <span class="badge bg-primary">Buyer Dashboard</span>
            }
        </div>
    </div>

    @if (!Model.Any()) {
        <div class="card p-5 text-center bg-light">
            <i class="bi bi-emoji-smile text-muted" style="font-size: 3rem;"></i>
            <p class="mt-3">No active disputes or claims found. Everything looks good!</p>
        </div>
    } else {
        <div class="table-responsive">
            <table class="table table-hover align-middle border shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th>Order #</th>
                        <th>Raised By</th>
                        <th>Details</th>
                        <th>Status</th>
                        <th>Resolution</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dispute in Model) {
                        <tr>
                            <td><strong>@dispute.orderId</strong></td>
                            <td>@dispute.raisedByNavigation?.username</td>
                            <td>
                                <div class="small text-truncate" style="max-width: 200px;" title="@dispute.description">
                                    @dispute.description
                                </div>
                            </td>
                            <td>
                                @if (dispute.status == "Pending") {
                                    <span class="badge rounded-pill bg-warning text-dark">Pending Review</span>
                                } else if (dispute.status == "Resolved") {
                                    <span class="badge rounded-pill bg-success">Resolved</span>
                                } else {
                                    <span class="badge rounded-pill bg-secondary">@dispute.status</span>
                                }
                            </td>
                            <td><span class="text-muted italic">@dispute.resolution</span></td>
                            <td>
                                <a asp-controller="Order" asp-action="MyOrders" class="btn btn-sm btn-outline-dark">View Order</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>
