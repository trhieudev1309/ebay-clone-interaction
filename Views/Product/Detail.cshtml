@using EbayChat.Entities;
@{
    var product = ViewBag.Product as Product;
    var reviews = ViewBag.Reviews as List<Review> ?? new List<Review>();
    var feedback = ViewBag.Feedback as Feedback;
    var category = product.category;
    ViewData["Title"] = (product == null) ? "Product Page" : product.title + " Page";

    double avgRating = reviews.Any() ? reviews.Average(r => r.rating ?? 0) : 0;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<style>
    .star-rating { color: #f1c40f; font-size: 1.2rem; }
    .seller-card { background: #f8f9fa; border: 1px solid #e9ecef; border-radius: 8px; padding: 15px; }
    .review-item { border-bottom: 1px solid #eee; padding: 15px 0; }
    .review-item:last-child { border-bottom: none; }
</style>

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">eBay</a></li>
        <li class="breadcrumb-item">
            <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@category.id">@category.name</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">@product.title</li>
    </ol>
</nav>

<div class="container mt-4">
    <div class="row">
        <!-- Main Content -->
        <div class="col-md-8">
            <div class="row">
                <div class="col-md-5">
                    <img src="@product.images" class="img-fluid border rounded" alt="@product.title" />
                </div>
                <div class="col-md-7">
                    <h2>@product.title</h2>
                    <div class="mb-2">
                        <span class="star-rating">
                            @for (int i = 1; i <= 5; i++) {
                                <i class="bi @(i <= Math.Round(avgRating) ? "bi-star-fill" : "bi-star")"></i>
                            }
                        </span>
                        <span class="ms-2 text-muted">(@reviews.Count reviews)</span>
                    </div>
                    <p class="text-muted">Category: @product.category.name</p>
                    <h3 class="text-danger fw-bold">$@product.price</h3>
                    <p class="mt-3">@product.description</p>

                    <form method="post" action="@Url.Action("BuyNow", "Order")" class="mt-4">
                        <input type="hidden" name="productId" value="@product.id" />
                        <div class="d-flex align-items-center mb-3">
                            <input type="number" name="quantity" value="1" min="1" class="form-control w-25 me-2" />
                            <button type="submit" class="btn btn-primary btn-lg px-4 me-2">
                                <i class="bi bi-cart"></i> Buy It Now
                            </button>
                            @if (Context.Session.GetInt32("userId") != product.sellerId && Context.Session.GetString("role")?.Trim().Equals("Buyer", StringComparison.OrdinalIgnoreCase) == true) {
                                <a href="/Chat/StartChat?receiverId=@product.sellerId&productId=@product.id" class="btn btn-outline-secondary">
                                    <i class="bi bi-chat-dots"></i> Message Seller
                                </a>
                            }
                        </div>
                    </form>
                </div>
            </div>

            <!-- Reviews Section -->
            <div class="mt-5">
                <hr />
                <h4>Ratings & Reviews</h4>
                @if (reviews.Any()) {
                    @foreach (var review in reviews) {
                        <div class="review-item">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold">@review.reviewer?.username</span>
                                <small class="text-muted">@review.createdAt?.ToString("MMM dd, yyyy")</small>
                            </div>
                            <div class="star-rating small mb-1">
                                @for (int i = 1; i <= 5; i++) {
                                    <i class="bi @(i <= review.rating ? "bi-star-fill" : "bi-star")"></i>
                                }
                            </div>
                            <p class="mb-0">@review.comment</p>
                        </div>
                    }
                } else {
                    <p class="text-muted italic">No reviews yet. Be the first to review!</p>
                }

                <!-- Add Review Form -->
                @if (Context.Session.GetInt32("userId") != null) {
                    <div class="card bg-light mt-4">
                        <div class="card-body">
                            <h5>Write a review</h5>
                            <form asp-controller="Review" asp-action="AddReview" method="post">
                                <input type="hidden" name="productId" value="@product.id" />
                                <div class="mb-3">
                                    <label class="form-label">Rating</label>
                                    <select name="rating" class="form-select w-25" required>
                                        <option value="5">5 - Excellent</option>
                                        <option value="4">4 - Very Good</option>
                                        <option value="3">3 - Average</option>
                                        <option value="2">2 - Poor</option>
                                        <option value="1">1 - Terrible</option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Your Comment</label>
                                    <textarea name="comment" class="form-control" rows="3" required placeholder="What did you think of the product?"></textarea>
                                </div>
                                <button type="submit" class="btn btn-dark">Submit Review</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Sidebar (Seller Info) -->
        <div class="col-md-4">
            <div class="seller-card">
                <h5>Seller Information</h5>
                <hr />
                <div class="d-flex align-items-center mb-2">
                    <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 40px; height: 40px;">
                        @product.seller?.username.Substring(0,1).ToUpper()
                    </div>
                    <div>
                        <div class="fw-bold">@product.seller?.username</div>
                        @if (feedback != null) {
                            <div class="text-primary small">
                                <i class="bi bi-star-fill"></i> @feedback.positiveRate?.ToString("0")% Positive Feedback
                            </div>
                        } else {
                            <div class="text-muted small">New Seller (No feedback yet)</div>
                        }
                    </div>
                </div>
                <div class="mt-3">
                    <a href="#" class="btn btn-sm btn-outline-primary w-100 mb-2">Visit Store</a>
                    <a href="#" class="btn btn-sm btn-outline-secondary w-100">Save this seller</a>
                </div>
            </div>
        </div>
    </div>
</div>